import { useState } from "react";
import { Heart, ShoppingBag, Star } from "lucide-react";
import productsData from "../../data/products.json";

const products = productsData as {
  id: number;
  name: string;
  category: string;
  price: number;
  originalPrice: number | null;
  rating: number;
  reviews: number;
  image: string;
  alt: string;
  badge: string;
  badgeColor: string;
}[];

export function NewProducts() {
  const [wishlist, setWishlist] = useState<number[]>([]);

  const toggleWishlist = (id: number) => {
    setWishlist((prev) => prev.includes(id) ? prev.filter((i) => i !== id) : [...prev, id]);
  };

  return (
    <section id="produse" className="py-20 px-6" style={{ background: "var(--secondary)" }}>
      <div className="max-w-7xl mx-auto">
        <div className="text-center mb-14">
          <p className="uppercase tracking-[0.2em] mb-2" style={{ fontFamily: "'DM Sans', sans-serif", fontSize: "0.7rem", color: "var(--accent)" }}>
            Tocmai sosite
          </p>
          <h2 style={{ fontFamily: "'Playfair Display', serif", fontSize: "clamp(1.8rem, 3vw, 2.5rem)", fontWeight: 600, color: "var(--foreground)" }}>
            Produse noi
          </h2>
          <div className="mx-auto mt-4" style={{ width: "48px", height: "2px", background: "var(--accent)" }} />
        </div>

        <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {products.map((product) => (
            <div key={product.id} className="group bg-card overflow-hidden cursor-pointer" style={{ boxShadow: "0 1px 4px rgba(42,35,24,0.07)" }}>
              <div className="relative overflow-hidden aspect-[5/6] bg-muted">
                <img src={product.image} alt={product.alt} className="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                <div className="absolute top-3 left-3 px-2.5 py-1" style={{ background: product.badgeColor, color: "#FFFFFF", fontFamily: "'DM Sans', sans-serif", fontSize: "0.7rem", letterSpacing: "0.06em", fontWeight: 500 }}>
                  {product.badge}
                </div>
                <button onClick={() => toggleWishlist(product.id)} className="absolute top-3 right-3 w-8 h-8 bg-white flex items-center justify-center transition-all duration-200 hover:scale-110" style={{ boxShadow: "0 2px 8px rgba(0,0,0,0.1)" }}>
                  <Heart size={15} style={{ color: wishlist.includes(product.id) ? "#c0392b" : "var(--muted-foreground)", fill: wishlist.includes(product.id) ? "#c0392b" : "none" }} />
                </button>
                <div className="absolute bottom-0 left-0 right-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
                  <button className="w-full flex items-center justify-center gap-2 py-3 text-white" style={{ background: "var(--accent)", fontFamily: "'DM Sans', sans-serif", fontSize: "0.8rem", letterSpacing: "0.08em", textTransform: "uppercase" }}>
                    <ShoppingBag size={14} /> Adaugă în coș
                  </button>
                </div>
              </div>
              <div className="p-4">
                <p style={{ fontFamily: "'DM Sans', sans-serif", fontSize: "0.7rem", color: "var(--accent)", letterSpacing: "0.1em", textTransform: "uppercase", marginBottom: "4px" }}>{product.category}</p>
                <h3 style={{ fontFamily: "'Playfair Display', serif", fontSize: "1rem", fontWeight: 600, color: "var(--foreground)", marginBottom: "6px" }}>{product.name}</h3>
                <div className="flex items-center gap-1.5 mb-3">
                  <div className="flex">
                    {[1,2,3,4,5].map((star) => (
