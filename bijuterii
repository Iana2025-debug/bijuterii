                  style={{ boxShadow: "0 2px 8px rgba(0,0,0,0.1)" }}>
                  <Heart size={15} style={{
                    color: wishlist.includes(p.id) ? "#c0392b" : "var(--muted-foreground)",
                    fill:  wishlist.includes(p.id) ? "#c0392b" : "none",
