                </button>
                <div className="absolute bottom-0 left-0 right-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
                  <button className="w-full flex items-center justify-center gap-2 py-3 text-white"
                    style={{ background: "var(--accent)", fontFamily: sans, fontSize: "0.8rem", letterSpacing: "0.08em", textTransform: "uppercase" }}>
                    <ShoppingBag size={14} /> Adaugă în coș
                  </button>
                </div>
              </div>
              <div className="p-4">
                <p style={{ fontFamily: sans, fontSize: "0.7rem", color: "var(--accent)", letterSpacing: "0.1em", textTransform: "uppercase", marginBottom: "4px" }}>
                  {p.category}
                </p>
                <h3 style={{ fontFamily: serif, fontSize: "1rem", fontWeight: 600, color: "var(--foreground)", marginBottom: "6px" }}>
                  {p.name}
                </h3>
                <div className="flex items-center gap-1.5 mb-3">
                  <div className="flex">
                    {[1,2,3,4,5].map((s) => (
                      <Star key={s} size={11} style={{ color: "#B08D57", fill: s <= Math.floor(p.rating) ? "#B08D57" : "none" }} />
                    ))}
